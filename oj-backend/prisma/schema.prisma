// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(uuid())
  createdAt   DateTime     @default(now())
  username    String
  email       String       @unique
  password    String      
  submissions Submission[]
  currentStreak Int      @default(0)
  maxStreak   Int      @default(0)
  lastActivityDate  DateTime?    @db.Date
  activities        DailyActivity[]
  rating          Int       @default(1200)
  battlesPlayed   Int       @default(0)
  battlesWon      Int       @default(0)
  battlesAsP1     Battle[]  @relation("BattlePlayer1")
  battlesAsP2     Battle[]  @relation("BattlePlayer2")
}

model Question {
  id          String       @id
  title       String
  statement   String
  difficulty  Difficulty
  examples    Json
  constraints String
  testCases   TestCase[]
  submissions Submission[]
  battles     Battle[]
  createdAt   DateTime     @default(now())
}

model Submission {
  id             String           @id @default(uuid())
  userId         String
  questionId     String
  code           String
  language       String
  status         SubmissionStatus
  verdict        Verdict?
  result         String?
  attempts       Int              @default(0)
  lastStartedAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
  @@index([status])
}

model TestCase {
  id             String   @id @default(uuid())
  questionId     String
  input          String
  expectedOutput String
  isHidden       Boolean  @default(true)
  order          Int
  timeLimitMs    Int      @default(2000)

  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@unique([questionId, order])
}

model DailyActivity {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  count       Int      @default(1)
  user User @relation(fields: [userId], references: [id])
  @@unique([userId, date])
}

model Battle {
  id            String        @id @default(uuid())
  player1Id     String
  player2Id     String
  questionId    String
  status        BattleStatus  @default(WAITING)
  winnerId      String?
  player1Time   Int?          
  player2Time   Int?
  player1Hints  Int           @default(0)
  player2Hints  Int           @default(0)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime      @default(now())

  player1       User          @relation("BattlePlayer1", fields: [player1Id], references: [id])
  player2       User          @relation("BattlePlayer2", fields: [player2Id], references: [id])
  question      Question      @relation(fields: [questionId], references: [id])

  @@index([player1Id])
  @@index([player2Id])
}

enum BattleStatus {
  WAITING     
  ACTIVE      
  COMPLETED   
  ABANDONED   
}

enum SubmissionStatus {
  RECEIVED
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum Verdict {
  AC
  WA
  TLE
  RTE
  CE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}