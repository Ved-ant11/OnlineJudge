{
  "id": "split-array-largest-sum",
  "title": "Split Array Largest Sum Minimized",
  "difficulty": "HARD",
  "statement": "Split array `nums` into `m` non-empty contiguous subarrays to **minimize the largest subarray sum**. Return that minimum.\n\n**Input:** First line: space-separated integers. Second line: m.\n**Output:** Minimized largest subarray sum.",
  "constraints": "- 1 \u2264 nums.length \u2264 1000\n- 0 \u2264 nums[i] \u2264 10\u2076\n- 1 \u2264 m \u2264 min(50, nums.length)",
  "examples": [
    {
      "input": "7 2 5 10 8\n2",
      "output": "18",
      "explanation": "[7,2,5],[10,8]: max(14,18)=18."
    },
    {
      "input": "1 2 3 4 5\n2",
      "output": "9",
      "explanation": "[1,2,3],[4,5]: max(6,9)=9."
    },
    {
      "input": "1 4 4\n3",
      "output": "4",
      "explanation": "[1],[4],[4]: max=4."
    }
  ],
  "testCases": [
    {
