{
  "id": "string-compression-k",
  "title": "String Compression with K Removals",
  "difficulty": "MEDIUM",
  "statement": "Run-length encoding length: 1 char\u21921, 2-9\u21922, 10-99\u21923, 100-999\u21924. Given string `s` and integer `k`, delete at most `k` characters to **minimize the RLE length**.\n\n**Input:** First line: string s. Second line: k.\n**Output:** Minimum encoded length.",
  "constraints": "- 1 \u2264 s.length \u2264 100\n- 0 \u2264 k \u2264 s.length",
  "examples": [
    {
      "input": "aaabcccd\n2",
      "output": "4",
      "explanation": "Delete 'b' and 'd' \u2192 'aaaccc' \u2192 a3c3 = 4 chars."
    },
    {
      "input": "aabbaa\n2",
      "output": "2",
      "explanation": "Delete both 'b's \u2192 'aaaa' \u2192 a4 = 2 chars."
    },
    {
      "input": "a\n1",
      "output": "0",
      "explanation": "Delete the only char. Empty string has length 0."
    }
  ],
  "testCases": [
    {
      "input": "aaabcccd\n2",
      "expectedOutput": "4",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "aabbaa\n2",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "a\n1",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "abc\n0",
      "expectedOutput": "3",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "aaaaaaaaaa\n0",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "aaaaaaaaaa\n9",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "aabbccddeeff\n4",
      "expectedOutput": "4",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "abcdefghijklmnopqrstuvwxyz\n26",
      "expectedOutput": "0",
      "order": 8,
      "isHidden": true
    }
  ]
}