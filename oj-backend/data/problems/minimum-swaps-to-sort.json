{
  "id": "minimum-swaps-to-sort",
  "title": "Minimum Swaps to Sort",
  "difficulty": "MEDIUM",
  "statement": "Given an array of `n` distinct integers, find the minimum number of swaps required to sort the array in ascending order.\n\n**Input:** Space-separated distinct integers.\n**Output:** Print the minimum number of swaps.",
  "constraints": "- 1 ≤ n ≤ 10⁵\n- 1 ≤ nums[i] ≤ 10⁶\n- All elements are distinct.",
  "examples": [
    { "input": "nums = [4, 3, 2, 1]", "output": "2", "explanation": "Swap (4,1) → [1,3,2,4]. Swap (3,2) → [1,2,3,4]. 2 swaps." },
    { "input": "nums = [1, 5, 4, 3, 2]","output": "2","explanation": "Cycle detection gives 2 swaps." },
    { "input": "nums = [1, 2, 3]",     "output": "0", "explanation": "Already sorted." }
  ],
  "testCases": [
    { "input": "4 3 2 1",     "expectedOutput": "2", "order": 1, "isHidden": false },
    { "input": "1 5 4 3 2",   "expectedOutput": "2", "order": 2, "isHidden": false },
    { "input": "1 2 3",       "expectedOutput": "0", "order": 3, "isHidden": false },
    { "input": "2 1",         "expectedOutput": "1", "order": 4, "isHidden": true },
    { "input": "1",           "expectedOutput": "0", "order": 5, "isHidden": true },
    { "input": "3 2 1 4 5",   "expectedOutput": "1", "order": 6, "isHidden": true },
    { "input": "5 4 3 2 1",   "expectedOutput": "2", "order": 7, "isHidden": true }
  ]
}
