{
  "id": "frequency-sort-stability",
  "title": "Frequency Sort Stability",
  "difficulty": "EASY",
  "statement": "Sort an array of integers by frequency **ascending** (least frequent first). For equal frequencies, sort by **value descending**.\n\n**Input:** Space-separated integers.\n**Output:** Sorted array space-separated.",
  "constraints": "- 1 \u2264 n \u2264 10\u2075\n- -10\u2074 \u2264 nums[i] \u2264 10\u2074",
  "examples": [
    {
      "input": "1 1 2 2 3 3 3",
      "output": "2 2 1 1 3 3 3",
      "explanation": "freq(1)=2, freq(2)=2, freq(3)=3. Freq=2: sort value desc \u2192 2 before 1. Result: 2 2 1 1 3 3 3."
    },
    {
      "input": "5 5 4 4 3",
      "output": "3 5 5 4 4",
      "explanation": "freq(3)=1 first. freq=2: value desc \u2192 5 before 4."
    },
    {
      "input": "1",
      "output": "1",
      "explanation": "Single element."
    }
  ],
  "testCases": [
    {
      "input": "1 1 2 2 3 3 3",
      "expectedOutput": "2 2 1 1 3 3 3",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "5 5 4 4 3",
      "expectedOutput": "3 5 5 4 4",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 2 3 4 5",
      "expectedOutput": "5 4 3 2 1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 1 1 3 2 2 2",
      "expectedOutput": "3 3 1 1 2 2 2",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "-1 -1 1 1 0",
      "expectedOutput": "0 1 1 -1 -1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "4 4 4 4",
      "expectedOutput": "4 4 4 4",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "2 2 2 1 1 1",
      "expectedOutput": "2 2 2 1 1 1",
      "order": 8,
      "isHidden": true
    }
  ]
}