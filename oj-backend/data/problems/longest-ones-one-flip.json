{
  "id": "longest-ones-one-flip",
  "title": "Longest Consecutive Ones with One Flip",
  "difficulty": "EASY",
  "statement": "Given a binary array `nums` (containing only 0s and 1s), find the maximum number of consecutive 1s you can get if you are allowed to flip **at most one** 0 to 1.\n\n**Input:** Space-separated integers (0s and 1s).\n**Output:** Print the maximum consecutive 1s achievable.",
  "constraints": "- 1 \u2264 nums.length \u2264 10\u2075\n- nums[i] is either 0 or 1.",
  "examples": [
    {
      "input": "nums = [1,0,1,1,0,1]",
      "output": "4",
      "explanation": "Flip index 1 \u2192 [1,1,1,1,0,1]. Max window = 4."
    },
    {
      "input": "nums = [1,1,1,1,1]",
      "output": "5",
      "explanation": "All ones, no flip needed."
    },
    {
      "input": "nums = [0,0,0]",
      "output": "1",
      "explanation": "Flip one 0, max streak = 1."
    }
  ],
  "testCases": [
    {
      "input": "1 0 1 1 0 1",
      "expectedOutput": "4",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 1 1 1 1",
      "expectedOutput": "5",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "0 0 0",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "0",
      "expectedOutput": "1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 0 0 1 0 1 1",
      "expectedOutput": "4",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "0 1 1 1 0 1 1 1 1 0",
      "expectedOutput": "8",
      "order": 7,
      "isHidden": true
    }
  ]
}