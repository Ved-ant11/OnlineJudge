{
  "id": "tiling-board",
  "title": "Tiling a Board",
  "difficulty": "EASY",
  "statement": "Count the number of ways to completely tile a `2 \u00d7 N` board using `1 \u00d7 2` dominoes. Return the answer modulo 10\u2079+7.\n\n**Input:** Single integer N.\n**Output:** Number of tilings mod 10\u2079+7.",
  "constraints": "- 0 \u2264 N \u2264 10\u2075",
  "examples": [
    {
      "input": "2",
      "output": "2",
      "explanation": "Two verticals, or two horizontals."
    },
    {
      "input": "3",
      "output": "3",
      "explanation": "Three tilings for a 2\u00d73 board."
    },
    {
      "input": "0",
      "output": "1",
      "explanation": "Empty board has exactly one tiling (do nothing)."
    }
  ],
  "testCases": [
