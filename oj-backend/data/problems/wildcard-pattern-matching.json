{
  "id": "wildcard-pattern-matching",
  "title": "Wildcard Pattern Matching",
  "difficulty": "HARD",
  "statement": "Given a string `s` and a pattern `p` containing `?` (matches any single character) and `*` (matches any sequence including empty), return `true` if the pattern matches the entire string.\n\n**Input:**\n- Line 1: string `s`.\n- Line 2: pattern `p`.\n\n**Output:** Print `true` or `false`.",
  "constraints": "- 0 \u2264 s.length \u2264 2000\n- 0 \u2264 p.length \u2264 2000\n- s contains only lowercase letters.\n- p contains lowercase letters, `?`, and `*`.",
  "examples": [
    {
      "input": "s=aa, p=a",
      "output": "false",
      "explanation": "Pattern 'a' only matches one 'a'."
    },
    {
      "input": "s=aa, p=*",
      "output": "true",
      "explanation": "'*' matches everything."
    },
    {
      "input": "s=adceb, p=*a*b",
      "output": "true",
      "explanation": "'*' matches 'dce' in middle."
    }
  ],
  "testCases": [
    {
      "input": "aa\na",
      "expectedOutput": "false",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "aa\n*",
      "expectedOutput": "true",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "adceb\n*a*b",
      "expectedOutput": "true",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "cb\n?a",
      "expectedOutput": "false",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "acdcb\na*c?b",
      "expectedOutput": "false",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "abc\n???",
      "expectedOutput": "true",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "\n*",
      "expectedOutput": "true",
      "order": 7,
      "isHidden": true
    }
  ]
}