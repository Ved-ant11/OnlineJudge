{
  "id": "bracket-depth-sum",
  "title": "Bracket Depth Sum",
  "difficulty": "EASY",
  "statement": "Given a valid string of brackets `(`, `)` and digits `0\u20139`, compute the **depth-weighted sum**: each digit's contribution is `digit \u00d7 nesting depth` at the point it appears. Depth starts at 0 and increases by 1 on `(`, decreases by 1 on `)`.\n\n**Input:** A valid string of brackets and digits.\n**Output:** Single integer \u2014 the depth-weighted sum.",
  "constraints": "- 1 \u2264 s.length \u2264 10\u2074\n- s is a valid bracket sequence with digits only inside brackets",
  "examples": [
    {
      "input": "(1(2)3)",
      "output": "8",
      "explanation": "'(' \u2192 d=1; '1' \u2192 1\u00d71=1; '(' \u2192 d=2; '2' \u2192 2\u00d72=4; ')' \u2192 d=1; '3' \u2192 3\u00d71=3; ')' \u2192 d=0. Total=8."
    },
    {
      "input": "((2)(3))",
      "output": "10",
      "explanation": "'2' at depth 2 \u2192 +4. '3' at depth 2 \u2192 +6. Total=10."
    },
    {
      "input": "(9)",
      "output": "9",
      "explanation": "'9' at depth 1 \u2192 9\u00d71=9."
    }
  ],
  "testCases": [
    {
      "input": "(1(2)3)",
      "expectedOutput": "8",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "((2)(3))",
      "expectedOutput": "10",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "(9)",
      "expectedOutput": "9",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "((1))",
      "expectedOutput": "2",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "(1(1(1)))",
      "expectedOutput": "6",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "(0)",
      "expectedOutput": "0",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "((3)2(1))",
      "expectedOutput": "10",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "(1(2(3)2)1)",
      "expectedOutput": "19",
      "order": 8,
      "isHidden": true
    }
  ]
}