{
  "id": "minimum-swaps-k-together",
  "title": "Minimum Swaps to Group K Elements",
  "difficulty": "MEDIUM",
  "statement": "Given an array and a value `k`, find the minimum number of swaps to group all elements **\u2264 k** into a contiguous block anywhere in the array.\n\n**Input:** First line: space-separated integers. Second line: integer k.\n**Output:** Minimum swaps.",
  "constraints": "- 1 \u2264 n \u2264 10\u2075\n- 1 \u2264 nums[i] \u2264 10\u2079\n- 1 \u2264 k \u2264 10\u2079",
  "examples": [
    {
      "input": "2 1 5 6 3\n3",
      "output": "1",
      "explanation": "Elements \u22643: {2,1,3}, count=3. Slide window of size 3: min bad elements in any window=1. Answer=1."
    },
    {
      "input": "2 7 9 5 8 7 4\n5",
      "output": "2",
      "explanation": "Elements \u22645: {2,5,4}, count=3. Min bad count in any window of 3=2."
    },
    {
      "input": "1 2 3 4 5\n5",
      "output": "0",
      "explanation": "All elements \u22645, already contiguous."
    }
  ],
  "testCases": [
    {
      "input": "2 1 5 6 3\n3",
      "expectedOutput": "1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2 7 9 5 8 7 4\n5",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3 4 5\n5",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n1",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5 1 5 1 5\n2",
      "expectedOutput": "1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 3 5 7 9 2 4 6 8 10\n5",
      "expectedOutput": "2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "6 5 4 3 2 1\n3",
      "expectedOutput": "0",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "10 10 10 1 10 10\n5",
      "expectedOutput": "0",
      "order": 8,
      "isHidden": true
    }
  ]
}