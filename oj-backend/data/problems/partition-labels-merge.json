{
  "id": "partition-labels-merge",
  "title": "Partition Labels with Merge",
  "difficulty": "MEDIUM",
  "statement": "Partition string `s` into the maximum number of parts so each letter appears in at most one part. Then greedily **merge consecutive parts** whose combined length \u2264 k (left to right). Return final partition sizes.\n\n**Input:** First line: string s. Second line: integer k.\n**Output:** Space-separated partition sizes.",
  "constraints": "- 1 \u2264 s.length \u2264 500\n- 1 \u2264 k \u2264 s.length",
  "examples": [
    {
      "input": "ababcbacadefegdehijhklij\n10",
      "output": "9 7 8",
      "explanation": "Base partitions: 9,7,8. No consecutive pair sums \u226410. No merges."
    },
    {
      "input": "abcabc\n10",
      "output": "6",
      "explanation": "Only one base partition of size 6."
    },
    {
      "input": "abcd\n3",
      "output": "3 1",
      "explanation": "Base: 1,1,1,1. Merge: 1+1=2\u22643\u21922; 2+1=3\u22643\u21923; 3+1=4>3 stop. Result: 3,1."
    }
  ],
  "testCases": [
    {
      "input": "ababcbacadefegdehijhklij\n10",
      "expectedOutput": "9 7 8",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "abcabc\n10",
      "expectedOutput": "6",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "abcd\n3",
      "expectedOutput": "3 1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "a\n1",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "abcd\n10",
      "expectedOutput": "4",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "aabbcc\n5",
      "expectedOutput": "2 2 2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "eccbbbbdec\n6",
      "expectedOutput": "10",
      "order": 7,
      "isHidden": true
    }
  ]
}