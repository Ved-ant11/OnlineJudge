{
  "id": "sequence-reconstruction-unique",
  "title": "Unique Sequence Reconstruction",
  "difficulty": "HARD",
  "statement": "Given sequence `org` and list of subsequences `seqs`, determine if `org` is the **only** sequence that can be reconstructed. True iff: every value in seqs appears in org, every consecutive pair in each seq preserves org's order, AND every consecutive pair in org is constrained by at least one seq.\n\n**Input:** First line: org (space-separated). Second line: s. Next s lines: one seq each.\n**Output:** true or false.",
  "constraints": "- 1 \u2264 |org| \u2264 10\u2074\n- 1 \u2264 s \u2264 10\u2074",
  "examples": [
    {
      "input": "1 2 3\n3\n1 2\n1 3\n2 3",
      "output": "true",
      "explanation": "All consecutive pairs (1,2),(2,3) in org are covered. Unique."
    },
    {
      "input": "1 2 3\n2\n1 2\n1 3",
      "output": "false",
      "explanation": "Pair (2,3) not constrained \u2014 [1,3,2] also valid."
    },
    {
      "input": "1\n1\n1",
      "output": "true",
      "explanation": "Single element, trivially unique."
    }
  ],
  "testCases": [
    {
      "input": "1 2 3\n3\n1 2\n1 3\n2 3",
      "expectedOutput": "true",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 2 3\n2\n1 2\n1 3",
      "expectedOutput": "false",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1\n1\n1",
      "expectedOutput": "true",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 2\n1\n1 2",
      "expectedOutput": "true",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1 2\n1\n2 1",
      "expectedOutput": "false",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3 1 2\n2\n3 1\n3 2",
      "expectedOutput": "false",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 2 3 4\n3\n1 2\n2 3\n3 4",
      "expectedOutput": "true",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "4 1 5 2 6 3\n2\n5 2 6 3\n4 1 5 2",
      "expectedOutput": "true",
      "order": 8,
      "isHidden": true
    }
  ]
}