{
  "id": "score-sequence",
  "title": "Score Sequence",
  "difficulty": "EASY",
  "statement": "You are receiving scores one by one. After each new score arrives, report how many **previously received scores** are strictly less than the current one.\n\n**Input:** First line: n. Second line: n space-separated integers.\n**Output:** n space-separated counts.",
  "constraints": "- 1 \u2264 n \u2264 10\u2075\n- 0 \u2264 scores[i] \u2264 10\u2076",
  "examples": [
    {
      "input": "5\n1 2 3 4 5",
      "output": "0 1 2 3 4",
      "explanation": "Each new score beats all previous ones."
    },
    {
      "input": "5\n5 4 3 2 1",
      "output": "0 0 0 0 0",
      "explanation": "Each new score beats none of the previous."
    },
    {
      "input": "4\n4 1 3 2",
      "output": "0 0 1 1",
      "explanation": "4: none before. 1: 0 smaller. 3: only 1 is smaller (1 count). 2: only 1 is smaller (1 count)."
    }
  ],
  "testCases": [
    {
      "input": "5\n1 2 3 4 5",
      "expectedOutput": "0 1 2 3 4",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "5\n5 4 3 2 1",
      "expectedOutput": "0 0 0 0 0",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "4\n4 1 3 2",
      "expectedOutput": "0 0 1 1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n7",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3\n2 2 2",
      "expectedOutput": "0 0 0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "8\n3 1 4 1 5 9 2 6",
      "expectedOutput": "0 0 2 0 4 5 2 6",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "5\n3 1 4 1 5",
      "expectedOutput": "0 0 1 0 3",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "4\n0 0 1 0",
      "expectedOutput": "0 0 2 0",
      "order": 8,
      "isHidden": true
    }
  ]
}