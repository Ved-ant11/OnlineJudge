{
  "id": "rotate-image-90",
  "title": "Rotate Image 90 Degrees",
  "difficulty": "MEDIUM",
  "statement": "Given an `n x n` 2D matrix, rotate it 90 degrees clockwise **in-place** and print the result.\n\nThe trick: transpose then reverse each row.\n\n**Input:**\n- Line 1: integer `n`.\n- Next `n` lines: `n` space-separated integers per row.\n\n**Output:** Print the rotated matrix, each row on a new line.",
  "constraints": "- 1 ≤ n ≤ 20\n- -10³ ≤ matrix[i][j] ≤ 10³",
  "examples": [
    { "input": "n=3, matrix=[[1,2,3],[4,5,6],[7,8,9]]",                    "output": "7 4 1\n8 5 2\n9 6 3",             "explanation": "Transpose then reverse rows." },
    { "input": "n=4, matrix=[[5,1,9,11],[2,4,8,10],[13,3,6,7],[15,14,12,16]]","output": "15 13 2 5\n14 3 4 1\n12 6 8 9\n16 7 10 11","explanation": "4x4 rotation." }
  ],
  "testCases": [
    { "input": "3\n1 2 3\n4 5 6\n7 8 9",                      "expectedOutput": "7 4 1\n8 5 2\n9 6 3",                          "order": 1, "isHidden": false },
    { "input": "4\n5 1 9 11\n2 4 8 10\n13 3 6 7\n15 14 12 16","expectedOutput": "15 13 2 5\n14 3 4 1\n12 6 8 9\n16 7 10 11","order": 2, "isHidden": false },
    { "input": "1\n7",                                         "expectedOutput": "7",                                        "order": 3, "isHidden": true },
    { "input": "2\n1 2\n3 4",                                  "expectedOutput": "3 1\n4 2",                                  "order": 4, "isHidden": true },
    { "input": "3\n1 0 0\n0 1 0\n0 0 1",                      "expectedOutput": "0 0 1\n0 1 0\n1 0 0",                      "order": 5, "isHidden": true },
    { "input": "3\n9 8 7\n6 5 4\n3 2 1",                      "expectedOutput": "3 6 9\n2 5 8\n1 4 7",                      "order": 6, "isHidden": true }
  ]
}
