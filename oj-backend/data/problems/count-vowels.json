{
  "id": "count-vowels",
  "title": "Count Vowels in a String",
  "difficulty": "EASY",
  "statement": "Given a string `s`, return the number of vowels (`a`, `e`, `i`, `o`, `u`) in the string. Both uppercase and lowercase vowels should be counted.\n\n**Input:** A single string `s`.\n**Output:** Print the count of vowels.",
  "constraints": "- 1 ≤ s.length ≤ 10⁵\n- s consists of printable ASCII characters.",
  "examples": [
    { "input": "s = \"hello\"", "output": "2", "explanation": "'e' and 'o' are vowels." },
    { "input": "s = \"rhythm\"", "output": "0", "explanation": "No vowels present." },
    { "input": "s = \"Education\"", "output": "5", "explanation": "E, u, a, i, o are vowels." }
  ],
  "testCases": [
    { "input": "hello",       "expectedOutput": "2", "order": 1, "isHidden": false },
    { "input": "rhythm",      "expectedOutput": "0", "order": 2, "isHidden": false },
    { "input": "Education",   "expectedOutput": "5", "order": 3, "isHidden": false },
    { "input": "aeiouAEIOU",  "expectedOutput": "10","order": 4, "isHidden": true },
    { "input": "bcdfg",       "expectedOutput": "0", "order": 5, "isHidden": true },
    { "input": "The quick brown fox", "expectedOutput": "5", "order": 6, "isHidden": true },
    { "input": "a",           "expectedOutput": "1", "order": 7, "isHidden": true }
  ]
}
