{
  "id": "palindrome-partitioning-min-cuts",
  "title": "Palindrome Partitioning \u2014 Minimum Cuts",
  "difficulty": "HARD",
  "statement": "Given a string `s`, partition it such that every substring of the partition is a palindrome. Return the **minimum number of cuts** needed.\n\nFor example, `\"aab\"` requires 1 cut: `\"aa\" | \"b\"`. `\"a\"` requires 0 cuts.\n\n**Input:** A single string `s`.\n**Output:** Print the minimum number of cuts.",
  "constraints": "- 1 \u2264 s.length \u2264 2000\n- s consists of lowercase English letters only.",
  "examples": [
    {
      "input": "s = \"aab\"",
      "output": "1",
      "explanation": "\"aa\" | \"b\" \u2014 1 cut."
    },
    {
      "input": "s = \"a\"",
      "output": "0",
      "explanation": "Already a palindrome, no cuts needed."
    },
    {
      "input": "s = \"ab\"",
      "output": "1",
      "explanation": "\"a\" | \"b\" \u2014 1 cut."
    },
    {
      "input": "s = \"abcba\"",
      "output": "0",
      "explanation": "Whole string is a palindrome."
    }
  ],
  "testCases": [
    {
      "input": "aab",
      "expectedOutput": "1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "a",
      "expectedOutput": "0",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "ab",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "abcba",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "aabb",
      "expectedOutput": "1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "abcde",
      "expectedOutput": "4",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "ababababab",
      "expectedOutput": "1",
      "order": 7,
      "isHidden": true
    }
  ]
}