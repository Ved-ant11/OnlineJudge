{
  "id": "nesting-depth",
  "title": "Maximum Nesting Depth of Parentheses",
  "difficulty": "EASY",
  "statement": "Given a string containing digits, operators, and parentheses representing a valid arithmetic expression, return the maximum nesting depth of the parentheses.\n\n**Input:** A single string expression.\n**Output:** Print the maximum depth.",
  "constraints": "- 1 \u2264 s.length \u2264 100\n- s is a valid arithmetic expression with balanced parentheses.",
  "examples": [
    {
      "input": "s=(1+(2*3)+((8)/4))+1",
      "output": "3",
      "explanation": "((8)/4) has depth 3."
    },
    {
      "input": "s=(1)+((2))+(((3)))",
      "output": "3",
      "explanation": "(((3))) has depth 3."
    },
    {
      "input": "s=1+1",
      "output": "0",
      "explanation": "No parentheses."
    }
  ],
  "testCases": [
    {
      "input": "(1+(2*3)+((8)/4))+1",
      "expectedOutput": "3",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "(1)+((2))+(((3)))",
      "expectedOutput": "3",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1+1",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "(())",
      "expectedOutput": "2",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "((()))",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "(1)",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "((1+2)*(3+4))",
      "expectedOutput": "2",
      "order": 7,
      "isHidden": true
    }
  ]
}