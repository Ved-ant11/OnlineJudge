{
  "id": "zero-matrix",
  "title": "Zero Matrix",
  "difficulty": "MEDIUM",
  "statement": "Given an `m x n` matrix, if any cell contains `0`, set its entire row and column to `0`. Print the resulting matrix.\n\n**Input:**\n- Line 1: two integers `m` and `n`.\n- Next `m` lines: `n` space-separated integers per row.\n\n**Output:** Print the modified matrix, each row on a new line, space-separated.",
  "constraints": "- 1 ≤ m, n ≤ 200\n- -10⁹ ≤ matrix[i][j] ≤ 10⁹",
  "examples": [
    { "input": "m=3, n=3, matrix=[[1,1,1],[1,0,1],[1,1,1]]", "output": "1 0 1\n0 0 0\n1 0 1", "explanation": "Row 1 and column 1 zeroed." },
    { "input": "m=3, n=4, matrix=[[0,1,2,0],[3,4,5,2],[1,3,1,5]]","output": "0 0 0 0\n0 4 5 0\n0 3 1 0","explanation": "Row 0 and columns 0,3 zeroed." }
  ],
  "testCases": [
    { "input": "3 3\n1 1 1\n1 0 1\n1 1 1",     "expectedOutput": "1 0 1\n0 0 0\n1 0 1",         "order": 1, "isHidden": false },
    { "input": "3 4\n0 1 2 0\n3 4 5 2\n1 3 1 5","expectedOutput": "0 0 0 0\n0 4 5 0\n0 3 1 0","order": 2, "isHidden": false },
    { "input": "2 2\n1 2\n3 4",                 "expectedOutput": "1 2\n3 4",                   "order": 3, "isHidden": true },
    { "input": "2 2\n0 1\n1 1",                 "expectedOutput": "0 0\n0 1",                   "order": 4, "isHidden": true },
    { "input": "1 3\n1 0 1",                    "expectedOutput": "0 0 0",                     "order": 5, "isHidden": true },
    { "input": "3 3\n0 0 0\n0 0 0\n0 0 0",     "expectedOutput": "0 0 0\n0 0 0\n0 0 0",       "order": 6, "isHidden": true },
    { "input": "2 3\n1 2 3\n4 0 6",            "expectedOutput": "1 0 3\n0 0 0",               "order": 7, "isHidden": true }
  ]
}
