{
  "id": "run-length-score",
  "title": "Run-Length Score",
  "difficulty": "EASY",
  "statement": "The **run-length score** of a binary string is the sum of squares of lengths of all maximal consecutive runs of identical characters.\n\nFind the maximum run-length score achievable by flipping **at most one** character.\n\n**Input:** A binary string.\n**Output:** Maximum run-length score after at most one flip.",
  "constraints": "- 1 \u2264 s.length \u2264 10\u2075\n- s consists of '0' and '1' only",
  "examples": [
    {
      "input": "100001",
      "output": "26",
      "explanation": "Original: 1|0000|1 \u2192 1+16+1=18. Flip last '1'\u2192'0': '100000' \u2192 1+25=26."
    },
    {
      "input": "0000",
      "output": "16",
      "explanation": "Flipping any bit hurts the score. Keep as-is: 4\u00b2=16."
    },
    {
      "input": "01",
      "output": "4",
      "explanation": "Flip either bit: '11' or '00' \u2192 score=4."
    }
  ],
  "testCases": [
    {
      "input": "100001",
      "expectedOutput": "26",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "0000",
      "expectedOutput": "16",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "01",
      "expectedOutput": "4",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "0",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1100011",
      "expectedOutput": "21",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "10101",
      "expectedOutput": "11",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "0110",
      "expectedOutput": "10",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "111000111",
      "expectedOutput": "29",
      "order": 8,
      "isHidden": true
    }
  ]
}