{
  "id": "count-range-sum",
  "title": "Count of Range Sum",
  "difficulty": "HARD",
  "statement": "Given an integer array `nums` and two integers `lower` and `upper`, return the number of range sums that lie in `[lower, upper]` inclusive. A range sum is the sum of elements between indices `i` and `j` where `i \u2264 j`.\n\n**Input:**\n- Line 1: space-separated integers.\n- Line 2: two integers `lower upper`.\n\n**Output:** Print the count.",
  "constraints": "- 1 \u2264 nums.length \u2264 10\u2074\n- -10\u2075 \u2264 nums[i] \u2264 10\u2075\n- -10\u2079 \u2264 lower \u2264 upper \u2264 10\u2079",
  "examples": [
    {
      "input": "nums=[-2,5,-1], lower=-2, upper=2",
      "output": "3",
      "explanation": "Ranges: [-2],[-2,5,-1],[5,-1] have sums -2,2,4. Those in [-2,2]: -2 and 2. Wait recount: [-2]=\u22122\u2713,[5]=5\u2717,[-1]=\u22121\u2713,[-2,5]=3\u2717,[5,-1]=4\u2717,[-2,5,-1]=2\u2713. Count=3."
    },
    {
      "input": "nums=[0], lower=0, upper=0",
      "output": "1",
      "explanation": "[0] sums to 0."
    },
    {
      "input": "nums=[1,2,3], lower=0, upper=3",
      "output": "4",
      "explanation": "[1],[2],[3],[1,2] all in [0,3]."
    }
  ],
  "testCases": [
    {
      "input": "-2 5 -1\n-2 2",
      "expectedOutput": "3",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "0\n0 0",
      "expectedOutput": "1",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3\n0 3",
      "expectedOutput": "4",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n1 1",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "-1 -1\n-2 -1",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 2 3 4\n3 6",
      "expectedOutput": "5",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "0 0\n0 0",
      "expectedOutput": "3",
      "order": 7,
      "isHidden": true
    }
  ]
}