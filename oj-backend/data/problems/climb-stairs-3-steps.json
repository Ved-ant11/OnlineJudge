{
  "id": "climb-stairs-3-steps",
  "title": "Climb Stairs with 1, 2, or 3 Steps",
  "difficulty": "EASY",
  "statement": "A staircase has `n` steps. You can climb 1, 2, or 3 steps at a time. Count the number of distinct ways to reach the top.\n\n**Input:** A single integer `n`.\n**Output:** Print the number of distinct ways.",
  "constraints": "- 1 \u2264 n \u2264 35",
  "examples": [
    {
      "input": "n=3",
      "output": "4",
      "explanation": "(1,1,1),(1,2),(2,1),(3) = 4 ways."
    },
    {
      "input": "n=4",
      "output": "7",
      "explanation": "7 distinct combinations."
    },
    {
      "input": "n=1",
      "output": "1",
      "explanation": "Only one way: take 1 step."
    }
  ],
  "testCases": [
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "3",
      "expectedOutput": "4",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "4",
      "expectedOutput": "7",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "2",
      "expectedOutput": "2",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5",
      "expectedOutput": "13",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "7",
      "expectedOutput": "44",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "10",
      "expectedOutput": "274",
      "order": 7,
      "isHidden": true
    }
  ]
}