{
  "id": "balanced-split-cost",
  "title": "Minimum Cost Balanced Split",
  "difficulty": "MEDIUM",
  "statement": "Given array `nums`, split into exactly **two non-empty contiguous parts**. The cost is `|sum(left) - sum(right)|`. Find the minimum cost and all split indices (0-indexed, where left = nums[0..i] inclusive) achieving it.\n\n**Input:** Space-separated integers.\n**Output:** First line: minimum cost. Second line: space-separated valid split indices in sorted order.",
  "constraints": "- 2 \u2264 n \u2264 10\u2075\n- -10\u2074 \u2264 nums[i] \u2264 10\u2074",
  "examples": [
    {
      "input": "1 2 3 4",
      "output": "2\n2",
      "explanation": "i=0:|1-9|=8, i=1:|3-7|=4, i=2:|6-4|=2. Min=2 at i=2."
    },
    {
      "input": "3 3",
      "output": "0\n0",
      "explanation": "Only split i=0: |3-3|=0."
    },
    {
      "input": "1 -1 1 -1",
      "output": "0\n1",
      "explanation": "i=1: |(1-1)-(1-1)|=0. Min=0 at i=1."
    }
  ],
  "testCases": [
    {
      "input": "1 2 3 4",
      "expectedOutput": "2\n2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "3 3",
      "expectedOutput": "0\n0",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 -1 1 -1",
      "expectedOutput": "0\n1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 2",
      "expectedOutput": "1\n0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5 5 5 5",
      "expectedOutput": "0\n1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 2 3",
      "expectedOutput": "0\n1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "-1 -2 -3 -4",
      "expectedOutput": "2\n2",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "10 0 0 10",
      "expectedOutput": "0\n0 1 2",
      "order": 8,
      "isHidden": true
    }
  ]
}