{
  "id": "longest-subarray-equal-01",
  "title": "Longest Subarray with Equal 0s and 1s",
  "difficulty": "MEDIUM",
  "statement": "Given a binary array `nums`, find the maximum length of a contiguous subarray with an equal number of `0`s and `1`s.\n\n**Hint:** Replace `0` with `-1` and find the longest subarray with sum `0`.\n\n**Input:** Space-separated integers (0s and 1s).\n**Output:** Print the length of the longest such subarray.",
  "constraints": "- 1 ≤ nums.length ≤ 10⁵\n- nums[i] is 0 or 1.",
  "examples": [
    { "input": "nums = [0,1]",         "output": "2", "explanation": "Entire array has one 0 and one 1." },
    { "input": "nums = [0,1,0]",       "output": "2", "explanation": "Either [0,1] or [1,0]." },
    { "input": "nums = [0,0,1,1,0,0]", "output": "4", "explanation": "[0,0,1,1] or [1,1,0,0]." }
  ],
  "testCases": [
    { "input": "0 1",           "expectedOutput": "2", "order": 1, "isHidden": false },
    { "input": "0 1 0",         "expectedOutput": "2", "order": 2, "isHidden": false },
    { "input": "0 0 1 1 0 0",   "expectedOutput": "4", "order": 3, "isHidden": false },
    { "input": "1 1 1 1",       "expectedOutput": "0", "order": 4, "isHidden": true },
    { "input": "0 1 1 0 1 1 1 0","expectedOutput": "4","order": 5, "isHidden": true },
    { "input": "0 0 0 1 1 1",   "expectedOutput": "6", "order": 6, "isHidden": true },
    { "input": "1",             "expectedOutput": "0", "order": 7, "isHidden": true }
  ]
}
