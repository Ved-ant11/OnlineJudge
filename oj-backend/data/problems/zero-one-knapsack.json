{
  "id": "zero-one-knapsack",
  "title": "0/1 Knapsack Problem",
  "difficulty": "MEDIUM",
  "statement": "Given `n` items with weights and values, and a knapsack capacity `W`, find the maximum value you can carry. Each item can be picked at most once.\n\n**Input:**\n- Line 1: two integers `n` and `W`.\n- Line 2: space-separated weights.\n- Line 3: space-separated values.\n\n**Output:** Print the maximum value.",
  "constraints": "- 1 \u2264 n \u2264 100\n- 1 \u2264 W \u2264 1000\n- 1 \u2264 weights[i] \u2264 W\n- 1 \u2264 values[i] \u2264 1000",
  "examples": [
    {
      "input": "n=4, W=5, w=[2,3,4,5], v=[3,4,5,6]",
      "output": "7",
      "explanation": "Pick items 0+1 (weight=5, value=7)."
    },
    {
      "input": "n=3, W=7, w=[1,3,4,5], v=[1,4,5,7]",
      "output": "9",
      "explanation": "Pick items 1+2 (weight=7, value=9)."
    },
    {
      "input": "n=3, W=5, w=[1,2,3], v=[6,10,12]",
      "output": "22",
      "explanation": "Pick items 0+2 (weight=4, value=18)? No: 2+3=5, 10+12=22 \u2713."
    }
  ],
  "testCases": [
    {
      "input": "4 5\n2 3 4 5\n3 4 5 6",
      "expectedOutput": "7",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "4 7\n1 3 4 5\n1 4 5 7",
      "expectedOutput": "9",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "3 5\n1 2 3\n6 10 12",
      "expectedOutput": "22",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 3\n5\n10",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "2 10\n5 5\n10 10",
      "expectedOutput": "20",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 1\n1\n1",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "3 4\n2 3 4\n3 4 5",
      "expectedOutput": "7",
      "order": 7,
      "isHidden": true
    }
  ]
}