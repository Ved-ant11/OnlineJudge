{
  "id": "equilibrium-index",
  "title": "Find Equilibrium Index",
  "difficulty": "EASY",
  "statement": "The equilibrium index of an array is an index `i` such that the sum of elements at lower indices equals the sum of elements at higher indices. Return the first such index, or `-1` if none exists.\n\n**Input:** Space-separated integers.\n**Output:** Print the first equilibrium index, or `-1`.",
  "constraints": "- 1 \u2264 arr.length \u2264 10\u2075\n- -10\u2074 \u2264 arr[i] \u2264 10\u2074",
  "examples": [
    {
      "input": "[-7,1,5,2,-4,3,0]",
      "output": "3",
      "explanation": "Left sum=-1, right sum=-1. Index 3."
    },
    {
      "input": "[1,2,3]",
      "output": "-1",
      "explanation": "No equilibrium index."
    },
    {
      "input": "[1]",
      "output": "0",
      "explanation": "Single element, both sides empty = 0."
    }
  ],
  "testCases": [
    {
      "input": "-7 1 5 2 -4 3 0",
      "expectedOutput": "3",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 2 3",
      "expectedOutput": "-1",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "0 0 0 0",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1 3 5 2 2",
      "expectedOutput": "2",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "2 -1 -1",
      "expectedOutput": "0",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 2 3 4 6",
      "expectedOutput": "3",
      "order": 7,
      "isHidden": true
    }
  ]
}