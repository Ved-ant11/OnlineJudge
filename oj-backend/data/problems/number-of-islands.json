{
  "id": "number-of-islands",
  "title": "Number of Islands",
  "difficulty": "MEDIUM",
  "statement": "Given an `m x n` grid of `'1'` (land) and `'0'` (water), count the number of islands. An island is surrounded by water and formed by connecting adjacent lands horizontally or vertically.\n\n**Input:**\n- Line 1: two integers `m` and `n`.\n- Next `m` lines: a string of `n` characters (`'0'` or `'1'`) per row.\n\n**Output:** Print the number of islands.",
  "constraints": "- 1 ≤ m, n ≤ 300\n- grid[i][j] is '0' or '1'.",
  "examples": [
    { "input": "m=4, n=5 grid shown", "output": "1", "explanation": "All land cells connect into one island." },
    { "input": "m=4, n=5 grid shown", "output": "3", "explanation": "Three separate islands." }
  ],
  "testCases": [
    { "input": "4 5\n11110\n11010\n11000\n00000", "expectedOutput": "1", "order": 1, "isHidden": false },
    { "input": "4 5\n11000\n11000\n00100\n00011", "expectedOutput": "3", "order": 2, "isHidden": false },
    { "input": "1 1\n1",                          "expectedOutput": "1", "order": 3, "isHidden": true },
    { "input": "1 1\n0",                          "expectedOutput": "0", "order": 4, "isHidden": true },
    { "input": "2 2\n11\n11",                     "expectedOutput": "1", "order": 5, "isHidden": true },
    { "input": "3 3\n101\n010\n101",              "expectedOutput": "5", "order": 6, "isHidden": true },
    { "input": "2 5\n10101\n01010",               "expectedOutput": "5", "order": 7, "isHidden": true }
  ]
}
