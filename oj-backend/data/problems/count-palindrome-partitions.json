{
  "id": "count-palindrome-partitions",
  "title": "Count Palindrome Partitions into K Parts",
  "difficulty": "HARD",
  "statement": "Given string `s`, count the number of ways to split it into **exactly k non-empty palindromic substrings**. Return the answer mod 10^9+7.\n\n**Input:** First line: string s. Second line: k.\n**Output:** Number of valid partitions mod 10^9+7.",
  "constraints": "- 1 \u2264 s.length \u2264 1000\n- 1 \u2264 k \u2264 s.length",
  "examples": [
    {
      "input": "aab\n1",
      "output": "0",
      "explanation": "'aab' is not a palindrome. 0 ways."
    },
    {
      "input": "aab\n2",
      "output": "1",
      "explanation": "Only 'aa'+'b'. Both palindromes."
    },
    {
      "input": "aab\n3",
      "output": "1",
      "explanation": "'a'+'a'+'b'. All single chars are palindromes."
    }
  ],
  "testCases": [
    {
      "input": "aab\n1",
      "expectedOutput": "0",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "aab\n2",
      "expectedOutput": "1",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "aab\n3",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "aaa\n1",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "aaa\n2",
      "expectedOutput": "2",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "aaa\n3",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "abcba\n1",
      "expectedOutput": "1",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "abba\n2",
      "expectedOutput": "0",
      "order": 8,
      "isHidden": true
    }
  ]
}