{
  "id": "sum-of-digits",
  "title": "Sum of Digits",
  "difficulty": "EASY",
  "statement": "Given a non-negative integer `n`, return the sum of all its digits.\n\n**Input:** A single non-negative integer `n`.\n**Output:** Print the sum of digits.",
  "constraints": "- 0 ≤ n ≤ 10¹⁸",
  "examples": [
    { "input": "n = 1234", "output": "10", "explanation": "1 + 2 + 3 + 4 = 10." },
    { "input": "n = 0",    "output": "0",  "explanation": "Single digit 0." },
    { "input": "n = 999",  "output": "27", "explanation": "9 + 9 + 9 = 27." }
  ],
  "testCases": [
    { "input": "1234",               "expectedOutput": "10", "order": 1, "isHidden": false },
    { "input": "0",                  "expectedOutput": "0",  "order": 2, "isHidden": false },
    { "input": "999",                "expectedOutput": "27", "order": 3, "isHidden": false },
    { "input": "1000000000000000000","expectedOutput": "1",  "order": 4, "isHidden": true },
    { "input": "9999999999",         "expectedOutput": "90", "order": 5, "isHidden": true },
    { "input": "100",                "expectedOutput": "1",  "order": 6, "isHidden": true },
    { "input": "5",                  "expectedOutput": "5",  "order": 7, "isHidden": true }
  ]
}
