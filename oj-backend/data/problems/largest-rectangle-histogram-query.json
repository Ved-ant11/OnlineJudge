{
  "id": "largest-rectangle-histogram-query",
  "title": "Histogram Largest Rectangle After Updates",
  "difficulty": "HARD",
  "statement": "Given a histogram, process queries:\n- `U i h` \u2014 set bar at index i to height h\n- `Q l r` \u2014 find the largest rectangle area in bars l to r (inclusive)\n\n**Input:** First line: n q. Second line: n heights. Next q lines: queries.\n**Output:** One integer per Q query.",
  "constraints": "- 1 \u2264 n \u2264 5000\n- 1 \u2264 q \u2264 10\u2074\n- 0 \u2264 heights[i] \u2264 10\u2074",
  "examples": [
    {
      "input": "3 1\n3 3 3\nQ 0 2",
      "output": "9",
      "explanation": "All bars height 3, width 3. Area=9."
    },
    {
      "input": "5 2\n1 2 3 2 1\nQ 0 4\nQ 1 3",
      "output": "6\n6",
      "explanation": "Q(0,4): max rect=6. Q(1,3): [2,3,2] max rect=6."
    },
    {
      "input": "1 2\n5\nQ 0 0\nU 0 3",
      "output": "5",
      "explanation": "Q(0,0)=5. Update doesn't produce output."
    }
  ],
  "testCases": [
    {
      "input": "3 1\n3 3 3\nQ 0 2",
      "expectedOutput": "9",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "5 2\n1 2 3 2 1\nQ 0 4\nQ 1 3",
      "expectedOutput": "6\n6",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2\n5\nQ 0 0\nU 0 3",
      "expectedOutput": "5",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "4 3\n4 4 4 4\nQ 0 3\nU 2 1\nQ 0 3",
      "expectedOutput": "16\n4",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5 1\n0 0 0 0 0\nQ 0 4",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "4 2\n1 3 2 4\nQ 0 3\nQ 1 3",
      "expectedOutput": "6\n6",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "6 3\n2 1 5 6 2 3\nQ 0 5\nU 1 5\nQ 0 5",
      "expectedOutput": "10\n15",
      "order": 7,
      "isHidden": true
    }
  ]
}