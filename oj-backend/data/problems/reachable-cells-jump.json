{
  "id": "reachable-cells-jump",
  "title": "Reachable Cells",
  "difficulty": "EASY",
  "statement": "You are at index 0 of an array. From index `i`, you move to index `i + arr[i]` (which can be negative, moving backwards). Count how many **distinct indices** are reachable from index 0, including index 0 itself.\n\n**Input:** First line: n. Second line: n space-separated integers.\n**Output:** Number of reachable indices.",
  "constraints": "- 1 \u2264 n \u2264 10\u2075\n- -n \u2264 arr[i] \u2264 n",
  "examples": [
    {
      "input": "5\n2 3 0 1 4",
      "output": "2",
      "explanation": "0\u21922\u21920 (cycle). Reachable: {0, 2}."
    },
    {
      "input": "4\n1 1 1 1",
      "output": "4",
      "explanation": "0\u21921\u21922\u21923\u2192out. All 4 indices reachable."
    },
    {
      "input": "2\n1 -1",
      "output": "2",
      "explanation": "0\u21921\u21920 (cycle). Reachable: {0, 1}."
    }
  ],
  "testCases": [
    {
      "input": "5\n2 3 0 1 4",
      "expectedOutput": "2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "4\n1 1 1 1",
      "expectedOutput": "4",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "2\n1 -1",
      "expectedOutput": "2",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n0",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5\n4 0 -1 2 0",
      "expectedOutput": "2",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3\n2 -1 2",
      "expectedOutput": "2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "4\n3 1 0 2",
      "expectedOutput": "2",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "6\n1 2 3 -3 -2 -1",
      "expectedOutput": "6",
      "order": 8,
      "isHidden": true
    }
  ]
}