{
  "id": "sliding-window-maximum",
  "title": "Sliding Window Maximum",
  "difficulty": "MEDIUM",
  "statement": "Given an integer array `nums` and a sliding window of size `k`, find the maximum value in each window as it slides from left to right.\n\n**Input:**\n- Line 1: space-separated integers.\n- Line 2: integer `k`.\n\n**Output:** Print the maximums space-separated.",
  "constraints": "- 1 ≤ nums.length ≤ 10⁵\n- -10⁴ ≤ nums[i] ≤ 10⁴\n- 1 ≤ k ≤ nums.length",
  "examples": [
    { "input": "nums=[1,3,-1,-3,5,3,6,7], k=3", "output": "3 3 5 5 6 7", "explanation": "Windows: [1,3,-1]→3, [3,-1,-3]→3, [-1,-3,5]→5, [-3,5,3]→5, [5,3,6]→6, [3,6,7]→7." },
    { "input": "nums=[1], k=1",                  "output": "1",            "explanation": "Single element window." },
    { "input": "nums=[1,3,1,2,0,5], k=3",        "output": "3 3 2 5",      "explanation": "Four windows of size 3." }
  ],
  "testCases": [
    { "input": "1 3 -1 -3 5 3 6 7\n3", "expectedOutput": "3 3 5 5 6 7", "order": 1, "isHidden": false },
    { "input": "1\n1",                  "expectedOutput": "1",            "order": 2, "isHidden": false },
    { "input": "1 3 1 2 0 5\n3",       "expectedOutput": "3 3 2 5",      "order": 3, "isHidden": false },
    { "input": "5 4 3 2 1\n2",         "expectedOutput": "5 4 3 2",      "order": 4, "isHidden": true },
    { "input": "1 2 3 4 5\n5",         "expectedOutput": "5",            "order": 5, "isHidden": true },
    { "input": "9 11 8 5 7 10\n3",     "expectedOutput": "11 11 8 10",   "order": 6, "isHidden": true },
    { "input": "2 1 5 3 6 4 8 7\n4",   "expectedOutput": "5 6 6 8 8",   "order": 7, "isHidden": true }
  ]
}
