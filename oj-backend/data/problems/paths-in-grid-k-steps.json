{
  "id": "paths-in-grid-k-steps",
  "title": "Count Paths in Grid with Exactly K Steps",
  "difficulty": "MEDIUM",
  "statement": "Given a grid of size `m \u00d7 n`, count the number of unique paths from top-left to bottom-right moving only right or down in exactly `k` steps. Since you can only move right or down, `k` must equal `m+n-2` for any path to exist.\n\n**Input:**\n- Line 1: three integers `m`, `n`, and `k`.\n\n**Output:** Print the count of paths, or `0` if impossible.",
  "constraints": "- 1 \u2264 m, n \u2264 15\n- 0 \u2264 k \u2264 30",
  "examples": [
    {
      "input": "m=3, n=3, k=4",
      "output": "6",
      "explanation": "Must take 4 steps (2 right + 2 down). C(4,2)=6 paths."
    },
    {
      "input": "m=2, n=2, k=2",
      "output": "2",
      "explanation": "Right-Down or Down-Right."
    },
    {
      "input": "m=3, n=7, k=8",
      "output": "28",
      "explanation": "C(8,2)=28 paths."
    }
  ],
  "testCases": [
    {
      "input": "3 3 4",
      "expectedOutput": "6",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2 2 2",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "3 7 8",
      "expectedOutput": "28",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 1 0",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 3 5",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "4 4 6",
      "expectedOutput": "20",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "2 5 5",
      "expectedOutput": "5",
      "order": 7,
      "isHidden": true
    }
  ]
}