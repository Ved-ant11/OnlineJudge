{
  "id": "shortest-path-alternating-colors",
  "title": "Shortest Path Alternating Edge Colors",
  "difficulty": "HARD",
  "statement": "Given a directed graph of n nodes with red and blue edges, find the shortest path from node 0 to each node such that edge colors **strictly alternate**. Output -1 for unreachable nodes.\n\n**Input:** First line: n. Second line: r (red edges). Next r lines: u v. Next line: b (blue edges). Next b lines: u v.\n**Output:** n space-separated distances (0-indexed, 0 for node 0).",
  "constraints": "- 1 \u2264 n \u2264 100\n- 0 \u2264 red, blue edges \u2264 200",
  "examples": [
    {
      "input": "3\n1\n0 1\n2\n1 2\n0 2",
      "output": "0 1 1",
      "explanation": "0\u21921 via red (dist 1). 0\u21922 via blue (dist 1)."
    },
    {
      "input": "3\n1\n0 1\n1\n0 2",
      "output": "0 1 1",
      "explanation": "Red 0\u21921, Blue 0\u21922. Both reachable in 1 hop."
    },
    {
      "input": "2\n0\n1\n0 1",
      "output": "0 1",
      "explanation": "Only blue edge 0\u21921. Reachable in 1 hop."
    }
  ],
  "testCases": [
    {
      "input": "3\n1\n0 1\n2\n1 2\n0 2",
      "expectedOutput": "0 1 1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "3\n1\n0 1\n1\n0 2",
      "expectedOutput": "0 1 1",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "2\n0\n1\n0 1",
      "expectedOutput": "0 1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n0\n0",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "4\n2\n0 1\n1 2\n2\n1 2\n2 3",
      "expectedOutput": "0 1 2 -1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3\n2\n0 1\n0 2\n1\n1 2",
      "expectedOutput": "0 1 2",
      "order": 6,
      "isHidden": true
    }
  ]
}