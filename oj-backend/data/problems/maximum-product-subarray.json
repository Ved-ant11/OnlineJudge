{
  "id": "maximum-product-subarray",
  "title": "Maximum Product Subarray",
  "difficulty": "MEDIUM",
  "statement": "Given an integer array, find the contiguous subarray with the largest product. Track both max and min products since multiplying by a negative flips them.\n\n**Input:** Space-separated integers.\n**Output:** Print the maximum product.",
  "constraints": "- 1 \u2264 nums.length \u2264 2 \u00d7 10\u2074\n- -10 \u2264 nums[i] \u2264 10",
  "examples": [
    {
      "input": "[2,3,-2,4]",
      "output": "6",
      "explanation": "[2,3] has product 6."
    },
    {
      "input": "[-2,3,-4]",
      "output": "24",
      "explanation": "[-2,3,-4] = 24."
    },
    {
      "input": "[-2,0,-1]",
      "output": "0",
      "explanation": "Best is 0."
    }
  ],
  "testCases": [
    {
      "input": "2 3 -2 4",
      "expectedOutput": "6",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "-2 3 -4",
      "expectedOutput": "24",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "-2 0 -1",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "0 2",
      "expectedOutput": "2",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "-3 -1 -1",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 2 3",
      "expectedOutput": "6",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "-2 -3 4 -1",
      "expectedOutput": "24",
      "order": 7,
      "isHidden": true
    }
  ]
}