{
  "id": "exam-schedule",
  "title": "Exam Schedule Optimizer",
  "difficulty": "HARD",
  "statement": "You have `n` exams. Exam `i` has a deadline `d[i]` (must be completed by day d[i]) and a penalty `p[i]` if missed. You can complete exactly one exam per day. Find the **minimum total penalty** from missed exams.\n\n**Input:** First line: n. Next n lines: deadline penalty.\n**Output:** Minimum total penalty.",
  "constraints": "- 1 \u2264 n \u2264 10\u2075\n- 1 \u2264 deadline \u2264 n\n- 1 \u2264 penalty \u2264 10\u2076",
  "examples": [
    {
      "input": "4\n4 20\n2 60\n4 50\n3 30",
      "output": "20",
      "explanation": "Schedule: day1=exam2(d\u22642), day2=exam4(d\u22643), day3=exam3(d\u22644), day4=exam2... Miss exam1 with penalty 20. Min=20."
    },
    {
      "input": "3\n1 30\n1 60\n1 10",
      "output": "40",
      "explanation": "Only 1 slot for deadline=1. Schedule exam with highest penalty (60). Miss the other two: 30+10=40."
    },
    {
      "input": "2\n2 5\n1 10",
      "output": "0",
      "explanation": "Day1=exam2, day2=exam1. No misses."
    }
  ],
  "testCases": [
    {
      "input": "4\n4 20\n2 60\n4 50\n3 30",
      "expectedOutput": "0",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "3\n1 30\n1 60\n1 10",
      "expectedOutput": "40",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "2\n2 5\n1 10",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n1 100",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5\n1 10\n2 20\n3 30\n4 40\n5 50",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "5\n1 10\n1 20\n1 30\n1 40\n1 50",
      "expectedOutput": "100",
      "order": 6,
      "isHidden": true
    },
