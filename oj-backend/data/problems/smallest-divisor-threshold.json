{
  "id": "smallest-divisor-threshold",
  "title": "Find Smallest Divisor Given Threshold",
  "difficulty": "MEDIUM",
  "statement": "Given an array of integers and a threshold, find the smallest positive integer divisor such that the sum of `ceil(nums[i] / divisor)` for all `i` is less than or equal to the threshold.\n\n**Input:**\n- Line 1: space-separated integers.\n- Line 2: integer `threshold`.\n\n**Output:** Print the smallest valid divisor.",
  "constraints": "- 1 \u2264 nums.length \u2264 5 \u00d7 10\u2074\n- 1 \u2264 nums[i] \u2264 10\u2076\n- nums.length \u2264 threshold \u2264 10\u2076",
  "examples": [
    {
      "input": "nums=[1,2,5,9], threshold=6",
      "output": "5",
      "explanation": "divisor=5: ceil sums = 1+1+1+2=5 \u2264 6."
    },
    {
      "input": "nums=[44,22,33,11,1], threshold=5",
      "output": "44",
      "explanation": "divisor=44: sum=1+1+1+1+1=5 \u2264 5."
    },
    {
      "input": "nums=[1,2,3], threshold=6",
      "output": "1",
      "explanation": "divisor=1 gives sum=6 \u2264 6."
    }
  ],
  "testCases": [
    {
      "input": "1 2 5 9\n6",
      "expectedOutput": "5",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "44 22 33 11 1\n5",
      "expectedOutput": "44",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3\n6",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n1",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "2 3 5 7 11\n11",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "10 10 10\n3",
      "expectedOutput": "10",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 2 3 4 5\n8",
      "expectedOutput": "2",
      "order": 7,
      "isHidden": true
    }
  ]
}