{
  "id": "binary-matrix-rank",
  "title": "Binary Matrix Rank",
  "difficulty": "MEDIUM",
  "statement": "Given a binary matrix (values 0 and 1), compute its **rank over GF(2)** (arithmetic modulo 2). This is the maximum number of linearly independent rows, where row operations use XOR instead of subtraction.\n\n**Input:** First line: n m. Next n lines: m space-separated 0s and 1s.\n**Output:** Single integer \u2014 the rank.",
  "constraints": "- 1 \u2264 n, m \u2264 300\n- Values are 0 or 1",
  "examples": [
    {
      "input": "3 3\n1 0 1\n0 1 1\n1 1 0",
      "output": "2",
      "explanation": "Row0 XOR Row1 = Row2. So only 2 linearly independent rows."
    },
    {
      "input": "2 2\n1 0\n0 1",
      "output": "2",
      "explanation": "Identity matrix, full rank."
    },
    {
      "input": "2 2\n1 1\n1 1",
      "output": "1",
      "explanation": "Both rows are identical \u2014 rank 1."
    }
  ],
  "testCases": [
    {
      "input": "3 3\n1 0 1\n0 1 1\n1 1 0",
      "expectedOutput": "2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2 2\n1 0\n0 1",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "2 2\n1 1\n1 1",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "2 2\n0 0\n0 0",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 3\n1 0 0\n0 1 0\n0 0 1",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3 3\n1 1 0\n0 1 1\n1 0 1",
      "expectedOutput": "2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 1\n1",
      "expectedOutput": "1",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "3 4\n1 0 1 0\n0 1 0 1\n1 1 1 1",
      "expectedOutput": "3",
      "order": 8,
      "isHidden": true
    }
  ]
}