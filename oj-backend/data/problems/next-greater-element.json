{
  "id": "next-greater-element",
  "title": "Next Greater Element",
  "difficulty": "MEDIUM",
  "statement": "Given an array `nums`, for each element find the next greater element to its right. If no greater element exists, output `-1` for that position.\n\n**Input:** Space-separated integers representing the array.\n**Output:** Print the next greater element for each position, space-separated.",
  "constraints": "- 1 ≤ nums.length ≤ 10⁴\n- -10⁹ ≤ nums[i] ≤ 10⁹",
  "examples": [
    { "input": "nums = [4, 5, 2, 10]", "output": "5 10 10 -1", "explanation": "Next greater: 4→5, 5→10, 2→10, 10→none." },
    { "input": "nums = [3, 2, 1]",     "output": "-1 -1 -1",   "explanation": "Descending, no next greater for any." },
    { "input": "nums = [1, 3, 2, 4]",  "output": "3 4 4 -1",   "explanation": "Using a monotonic stack." }
  ],
  "testCases": [
    { "input": "4 5 2 10",  "expectedOutput": "5 10 10 -1",  "order": 1, "isHidden": false },
    { "input": "3 2 1",     "expectedOutput": "-1 -1 -1",    "order": 2, "isHidden": false },
    { "input": "1 3 2 4",   "expectedOutput": "3 4 4 -1",    "order": 3, "isHidden": false },
    { "input": "5",         "expectedOutput": "-1",           "order": 4, "isHidden": true },
    { "input": "1 2 3 4 5", "expectedOutput": "2 3 4 5 -1",  "order": 5, "isHidden": true },
    { "input": "5 4 3 2 1", "expectedOutput": "-1 -1 -1 -1 -1","order": 6,"isHidden": true },
    { "input": "2 7 3 5 1", "expectedOutput": "7 -1 5 -1 -1","order": 7, "isHidden": true }
  ]
}
